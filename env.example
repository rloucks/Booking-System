# ── Google OAuth (required) ────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: https://yourdomain.com/auth/google/callback

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Google Calendar (optional - creates events on booking) ─────────────────
# Use 'primary' for the signed-in user's calendar,
# or a shared resource calendar ID like: abc123@group.calendar.google.com
GOOGLE_CALENDAR_ID=primary

# ── Google Workspace Directory (optional - for user autocomplete) ──────────
# Requires a Service Account with Domain-Wide Delegation
# Download the JSON key file and reference it here
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account-key.json
GOOGLE_ADMIN_EMAIL=admin@yourcompany.com

# ── Access Control ─────────────────────────────────────────────────────────
# Only allow users from this domain to sign in (leave blank to allow any Google account)
ALLOWED_DOMAIN=yourcompany.com

# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@yourcompany.com,it@yourcompany.com

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
SESSION_SECRET=change-this-to-a-long-random-string-in-production
