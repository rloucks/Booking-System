# ── Google OAuth (required for production) ─────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here
GOOGLE_REDIRECT_URI=https://booking.anvil.ai/auth/google/callback

# ── Google Calendar (optional) ─────────────────────────────────────────────
GOOGLE_CALENDAR_ID=primary

# ── Google Workspace Directory (optional) ──────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account-key.json
GOOGLE_ADMIN_EMAIL=admin@yourcompany.com

# ── Access Control ─────────────────────────────────────────────────────────
ALLOWED_DOMAIN=yourcompany.com
ADMIN_EMAILS=admin@yourcompany.com,it@yourcompany.com

# ── SSL Certificate ────────────────────────────────────────────────────────
# Domain name matching your Let's Encrypt cert
# Cert must exist at /etc/letsencrypt/live/<CERT_DOMAIN>/
CERT_DOMAIN=booking.anvil.ai

# ── Demo mode ──────────────────────────────────────────────────────────────
# true = bypass Google OAuth, login with any email
# Auto-enabled if GOOGLE_CLIENT_ID is not set
DEMO_MODE=false

# ── n8n webhooks (optional) ────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-server/webhook/deskbook

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
SESSION_SECRET=change-this-to-a-long-random-string
